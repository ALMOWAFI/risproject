<launch>

<!-- Test/Demo launch file -->

<param name="robot_description" textfile="$(find memory_game)/urdf/panda.urdf"/>

<node pkg="robot_state_publisher"
      type="robot_state_publisher"
      name="robot_state_publisher"/>

<node pkg="joint_state_publisher"
      type="joint_state_publisher"
      name="joint_state_publisher"/>

<!-- Static transform -->
<node pkg="tf2_ros"
      type="static_transform_publisher"
      name="world_to_panda"
      args="0 0 0 0 0 0 world panda_link0"/>

<!-- Game parameters -->
<rosparam file="$(find memory_game)/config/game_params.yaml" command="load"/>

<!-- Vision Node -->
<node name="vision_node"
      pkg="memory_game"
      type="vision_node"
      output="screen">
  <!-- In test mode we use manual script input, so disable auto hand-selection -->
  <param name="enable_player_detection" value="false"/>
</node>

<!-- Game Node -->
<node name="game_node"
      pkg="memory_game"
      type="game_node"
      output="screen">
  <!-- Slower/easier timings for manual testing -->
  <param name="show_hold_sec" value="2.0"/>
  <param name="between_show_sec" value="1.0"/>
  <param name="player_timeout_sec" value="60.0"/>
</node>

<!-- Motion Node -->
<node name="motion_node"
      pkg="memory_game"
      type="motion_node"
      output="screen"/>

<!-- RViz -->
<node name="rviz"
      pkg="rviz"
      type="rviz"
      args="-d $(find memory_game)/config/rviz_config.rviz"
      output="screen"/>

</launch>
