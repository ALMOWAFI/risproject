<?xml version="1.0"?>
<launch>
    <!-- Arguments -->
    <arg name="use_rviz" default="true"/>
    <arg name="use_real_robot" default="false"/>
    <arg name="enable_debug_images" default="true"/>
    
    <!-- RealSense camera with aligned depth enabled -->
    <arg name="start_camera" default="true"/>
    <include if="$(arg start_camera)" file="$(find realsense2_camera)/launch/rs_camera.launch">
        <arg name="camera"        value="realsense"/>
        <arg name="align_depth"   value="true"/>
        <arg name="enable_sync"   value="true"/>
        <arg name="enable_color"  value="true"/>
        <arg name="enable_depth"  value="true"/>
    </include>

    <!-- Game parameters -->
    <rosparam file="$(find memory_game)/config/game_params.yaml" command="load"/>
    
    <!-- Vision Node -->
    <node name="vision_node" pkg="memory_game" type="vision_node" output="screen">
        <param name="color_topic" value="/realsense/color/image_raw"/>
        <param name="depth_topic" value="/realsense/aligned_depth_to_color/image_raw"/>
        <param name="camera_info_topic" value="/realsense/color/camera_info"/>
        <param name="target_frame" value="panda_link0"/>
        <param name="enable_debug_images" value="$(arg enable_debug_images)"/>
    </node>
    
    <!-- Game Logic Node -->
    <node name="game_node" pkg="memory_game" type="game_node" output="screen">
    </node>
    
    <!-- Motion Node -->
    <node name="motion_node" pkg="memory_game" type="motion_node" output="screen">
    </node>
    
    <!-- RViz (optional) -->
    <node if="$(arg use_rviz)" name="rviz" pkg="rviz" type="rviz"
          args="-d $(find memory_game)/config/rviz_config.rviz" output="screen"/>

    <!-- Real robot bringup (optional, for lab/hardware use) -->
    <include if="$(arg use_real_robot)" file="$(find memory_game)/launch/real_robot.launch"/>

</launch>
