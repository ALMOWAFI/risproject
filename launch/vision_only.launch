<?xml version="1.0"?>
<launch>
    <!-- Launch only real vision node -->
    
    <!-- Vision Node -->
    <node name="vision_node" pkg="memory_game" type="vision_node" output="screen">
        <param name="color_topic" value="/camera/color/image_raw"/>
        <param name="depth_topic" value="/camera/aligned_depth_to_color/image_raw"/>
        <param name="camera_info_topic" value="/camera/color/camera_info"/>
        <param name="target_frame" value="panda_link0"/>
    </node>
    
    <!-- Image viewer for debugging -->
    <node name="image_view" pkg="image_view" type="image_view">
        <remap from="image" to="/camera/color/image_raw"/>
    </node>
    
    <!-- RViz for visualization -->
    <node name="rviz" pkg="rviz" type="rviz" 
          args="-d $(find memory_game)/config/rviz_config.rviz"/>
    
</launch>
