<?xml version="1.0"?>
<launch>
    <!-- Launch only real vision node -->
    <arg name="use_rviz" default="true"/>
    <arg name="use_image_view" default="false"/>
    <arg name="enable_debug_images" default="true"/>

    <!-- Load tuned vision/game params used elsewhere in the repo -->
    <rosparam file="$(find memory_game)/config/game_params.yaml" command="load"/>
    
    <!-- Vision Node -->
    <node name="vision_node" pkg="memory_game" type="vision_node" output="screen">
        <param name="color_topic" value="/realsense/color/image_raw"/>
        <param name="depth_topic" value="/realsense/aligned_depth_to_color/image_raw"/>
        <param name="camera_info_topic" value="/realsense/color/camera_info"/>
        <param name="target_frame" value="panda_link0"/>
        <param name="enable_debug_images" value="$(arg enable_debug_images)"/>
    </node>
    
    <!-- Image viewer for debugging -->
    <node if="$(arg use_image_view)" name="image_view" pkg="image_view" type="image_view">
        <remap from="image" to="/realsense/color/image_raw"/>
    </node>
    
    <!-- RViz for visualization -->
    <node if="$(arg use_rviz)" name="rviz" pkg="rviz" type="rviz" 
          args="-d $(find memory_game)/config/rviz_config.rviz"/>
    
</launch>
